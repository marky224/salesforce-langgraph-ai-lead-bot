# =============================================================================
# AI Sales Lead Bot — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.
# =============================================================================

# --- LLM Configuration ------------------------------------------------------
LLM_PROVIDER=xAI                  # anthropic | openai | groq | xai
LLM_MODEL=                              # Optional override (default per provider)
LLM_TEMPERATURE=0.7

# Provider API keys (only the active provider's key is required)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
XAI_API_KEY=

# --- Salesforce OAuth --------------------------------------------------------
SF_INSTANCE_URL=https://your-domain.develop.my.salesforce.com
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_USERNAME=
SF_PASSWORD=
SF_SECURITY_TOKEN=

# --- Server ------------------------------------------------------------------
BACKEND_URL=http://localhost:8000
CORS_ORIGINS=https://markandrewmarquez.com,https://your-widget.azurestaticapps.net,http://localhost:8000,http://127.0.0.1:5500
LOG_LEVEL=INFO

# --- Azure Container Apps (production) --------------------------------------
AZURE_RESOURCE_GROUP=
AZURE_CONTAINER_APP_NAME=salesforce-langgraph-ai-lead-bot
AZURE_CONTAINER_APPS_ENVIRONMENT=
