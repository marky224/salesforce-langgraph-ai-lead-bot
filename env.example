# =============================================================================
# AI Sales Lead Bot — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.
# =============================================================================

# --- LLM Configuration ------------------------------------------------------
LLM_PROVIDER=xai                         # anthropic | openai | groq | xai
LLM_MODEL=                               # Optional override (default per provider)
LLM_TEMPERATURE=0.7

# Provider API keys (only the active provider's key is required)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
XAI_API_KEY=

# --- Salesforce OAuth --------------------------------------------------------
SF_INSTANCE_URL=https://your-domain.develop.my.salesforce.com
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_USERNAME=
SF_PASSWORD=
SF_SECURITY_TOKEN=

# --- Server ------------------------------------------------------------------
BACKEND_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000,https://markandrewmarquez.com,https://zealous-moss-0360b7210.7.azurestaticapps.net
LOG_LEVEL=INFO

# --- Azure Deployment (reference) -------------------------------------------
# Resource Group:        rg-ai-lead-bot
# Container App:         salesforce-langgraph-ai-lead-bot
# Container Registry:    aileadbotacr
# Static Web App:        ai-lead-bot-widget
# Region:                centralus
